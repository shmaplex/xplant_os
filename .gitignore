# ---------------------------------------------------------------------------
# IMPORTANT: API keys and credentials
# ---------------------------------------------------------------------------
# Never commit files containing real credentials.
# config.h and config.json are personal device configs — keep them local.

# Arduino / ESP32 device config (contains API key, Wi-Fi password)
devices/arduino/**/config.h

# Raspberry Pi gateway config (contains API key)
devices/raspberry-pi/**/config.json

